---
import type { ProductCategory } from '@/data/inventory';
interface Props {
  name: string;
  category: ProductCategory;
  shell?: string;
  cabinet?: string;
  accent?: string;
  class?: string;
}
const {
  name,
  category,
  shell = '#eef4f2',
  cabinet = '#2b373b',
  accent = '#51c1ca',
  class: className = '',
} = Astro.props;
const isLong = category === 'swim-spas';
const isSauna = category === 'saunas';
const isCold = category === 'cold-plunge-tubs';
const isAccessory = ['gazebos', 'patio-heaters', 'pizza-ovens', 'massage-chairs', 'chemicals-filters'].includes(
  category,
);
---

<div
  class:list={['product-visual', className]}
  style={`--shell:${shell};--cabinet:${cabinet};--accent:${accent};`}
>
  <svg
    viewBox={isLong ? '0 0 760 390' : '0 0 620 420'}
    role="img"
    aria-label={`${name} conceptual product illustration`}
  >
    <defs>
      <linearGradient id={`pv-cabinet-${name}`} x1="0" y1="0" x2="0" y2="1"
        ><stop offset="0" stop-color="var(--cabinet)" stop-opacity=".78"></stop><stop
          offset="1"
          stop-color="var(--cabinet)"></stop></linearGradient
      >
      <linearGradient id={`pv-water-${name}`} x1="0" y1="0" x2="1" y2="1"
        ><stop offset="0" stop-color="#c9f6f5"></stop><stop offset=".52" stop-color="var(--accent)"></stop><stop
          offset="1"
          stop-color="#178d9e"></stop></linearGradient
      >
      <filter id={`pv-shadow-${name}`} x="-20%" y="-20%" width="140%" height="180%"
        ><feDropShadow dx="0" dy="22" stdDeviation="18" flood-opacity=".22"></feDropShadow></filter
      >
    </defs>
    {
      isLong ? (
        <g filter={`url(#pv-shadow-${name})`}>
          <path
            d="M90 88h560c36 0 65 29 65 65v125c0 36-29 65-65 65H90c-36 0-65-29-65-65V153c0-36 29-65 65-65Z"
            fill={`url(#pv-cabinet-${name})`}
          />
          <path
            d="M92 62h556c35 0 63 28 63 63v116c0 35-28 63-63 63H92c-35 0-63-28-63-63V125c0-35 28-63 63-63Z"
            fill="var(--shell)"
          />
          <path
            d="M107 90h526c28 0 50 22 50 50v86c0 28-22 50-50 50H107c-28 0-50-22-50-50v-86c0-28 22-50 50-50Z"
            fill={`url(#pv-water-${name})`}
          />
          <path
            d="M120 120c70 33 116 32 186 0 70-33 116-33 186 0 70 33 112 31 153 4"
            fill="none"
            stroke="#fff"
            stroke-opacity=".45"
            stroke-width="7"
            stroke-linecap="round"
          />
          <path
            d="M120 154c70 33 116 32 186 0 70-33 116-33 186 0 70 33 112 31 153 4"
            fill="none"
            stroke="#fff"
            stroke-opacity=".33"
            stroke-width="5"
            stroke-linecap="round"
          />
          <path
            d="M561 95h72c25 0 45 20 45 45v86c0 25-20 45-45 45h-72v-176Z"
            fill="var(--shell)"
            stroke="#cad7d3"
            stroke-width="3"
          />
          <g fill="none" stroke="#8aa19e" stroke-width="5" opacity=".7">
            <>
              <circle cx="618" cy="148" r="9" />
              <circle cx="618" cy="183" r="9" />
              <circle cx="618" cy="218" r="9" />
            </>
          </g>
        </g>
      ) : isSauna ? (
        <g filter={`url(#pv-shadow-${name})`}>
          <path
            d="M120 130c0-54 44-98 98-98h184c54 0 98 44 98 98v210H120V130Z"
            fill="var(--shell)"
            stroke="rgba(45,26,12,.18)"
            stroke-width="5"
          />
          <path
            d="M156 143c0-36 29-65 65-65h178c36 0 65 29 65 65v197H156V143Z"
            fill="url(#pv-cabinet-${name})"
          />
          <path d="M238 119h144v221H238V119Z" fill="#f8ead7" opacity=".92" />
          <>
            <path d="M261 147h98v70h-98z" fill="#22333a" opacity=".82" />
            <path d="M275 281h70" stroke="#7c583b" stroke-width="12" stroke-linecap="round" />
          </>
          <path
            d="M146 140h328M133 197h354M124 254h372M120 311h380"
            stroke="#2c1b12"
            stroke-opacity=".2"
            stroke-width="4"
          />
        </g>
      ) : isCold ? (
        <g filter={`url(#pv-shadow-${name})`}>
          <path
            d="M125 124h370c36 0 65 29 65 65v98c0 36-29 65-65 65H125c-36 0-65-29-65-65v-98c0-36 29-65 65-65Z"
            fill={`url(#pv-cabinet-${name})`}
          />
          <path
            d="M126 88h368c35 0 63 28 63 63v82c0 35-28 63-63 63H126c-35 0-63-28-63-63v-82c0-35 28-63 63-63Z"
            fill="var(--shell)"
          />
          <path
            d="M147 121h326c27 0 49 22 49 49v43c0 27-22 49-49 49H147c-27 0-49-22-49-49v-43c0-27 22-49 49-49Z"
            fill={`url(#pv-water-${name})`}
          />
          <path
            d="M137 160c54 24 93 24 147 0s93-24 147 0"
            fill="none"
            stroke="#fff"
            stroke-width="7"
            stroke-opacity=".45"
            stroke-linecap="round"
          />
          <g fill="#fff" opacity=".82">
            <>
              <circle cx="186" cy="184" r="8" />
              <circle cx="229" cy="203" r="6" />
              <circle cx="390" cy="190" r="9" />
            </>
          </g>
        </g>
      ) : isAccessory ? (
        <g filter={`url(#pv-shadow-${name})`}>
          <rect x="95" y="116" width="430" height="210" rx="30" fill={`url(#pv-cabinet-${name})`} />
          <path d="M112 132h396v156H112z" fill="var(--shell)" opacity=".95" />
          <path
            d="M156 288V132M464 288V132M112 176h396M112 234h396"
            stroke="var(--cabinet)"
            stroke-opacity=".22"
            stroke-width="7"
          />
          <circle cx="310" cy="210" r="58" fill="var(--accent)" opacity=".78" />
          <path
            d="M278 210h64M310 178v64"
            stroke="#fff"
            stroke-width="8"
            stroke-linecap="round"
            opacity=".82"
          />
        </g>
      ) : (
        <g filter={`url(#pv-shadow-${name})`}>
          <path
            d="M105 113h410c42 0 76 34 76 76v117c0 42-34 76-76 76H105c-42 0-76-34-76-76V189c0-42 34-76 76-76Z"
            fill={`url(#pv-cabinet-${name})`}
          />
          <path
            d="M107 81h406c41 0 74 33 74 74v110c0 41-33 74-74 74H107c-41 0-74-33-74-74V155c0-41 33-74 74-74Z"
            fill="var(--shell)"
          />
          <path
            d="M126 111h368c34 0 62 28 62 62v75c0 34-28 62-62 62H126c-34 0-62-28-62-62v-75c0-34 28-62 62-62Z"
            fill={`url(#pv-water-${name})`}
          />
          <path
            d="M94 164c45-38 82-38 127 0s82 38 127 0 82-38 127 0"
            fill="none"
            stroke="#fff"
            stroke-opacity=".42"
            stroke-width="7"
            stroke-linecap="round"
          />
          <g fill="var(--shell)" stroke="#cbd8d5" stroke-width="3">
            <>
              <path d="M88 126c28 10 48 32 53 59s-6 56-28 75l-22-19c12-11 19-28 16-44s-14-30-30-36l11-35Z" />
              <path d="M532 130c-28 10-48 32-53 59s6 56 28 75l22-19c-12-11-19-28-16-44s14-30 30-36l-11-35Z" />
              <path d="M230 284c14-30 42-49 75-49s61 19 75 49l-32 14c-8-18-24-29-43-29s-36 11-44 29l-31-14Z" />
            </>
          </g>
          <g fill="none" stroke="#8ca6a2" stroke-width="5" opacity=".75">
            <>
              <circle cx="110" cy="187" r="8" />
              <circle cx="110" cy="215" r="8" />
              <circle cx="510" cy="187" r="8" />
              <circle cx="510" cy="215" r="8" />
              <circle cx="286" cy="271" r="7" />
              <circle cx="310" cy="265" r="7" />
              <circle cx="334" cy="271" r="7" />
            </>
          </g>
        </g>
      )
    }
  </svg>
</div>
