---
import Layout from '@/layouts/Layout.astro';
import Icon from '@/components/Icon.astro';
---

<Layout title="Thank You | World of Spas" noindex={true}
  ><section class="page-hero" style="min-height:70vh;display:flex;align-items:center">
    <div class="container page-hero__inner">
      <span class="eyebrow eyebrow--light">Request received</span><h1>Thank you. We’ll be in touch.</h1><p
        class="page-hero__copy"
      >
        A showroom specialist will review your request and follow up with the right next step.
      </p><div class="page-hero__actions">
        <a class="button button--light" href="/">Return home <Icon name="arrow" size={18} /></a><a
          class="button button--outline-light"
          href="/products">Continue shopping</a
        >
      </div>
    </div>
  </section></Layout
>
