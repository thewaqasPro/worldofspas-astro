---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Accessibility | World of Spas"
  ><section class="page-hero">
    <div class="container page-hero__inner">
      <span class="eyebrow eyebrow--light">Accessibility</span><h1>A more usable website for more people.</h1><p
        class="page-hero__copy"
      >
        This template includes skip links, semantic landmarks, keyboard-aware menus, labels, reduced-motion
        support, and responsive layouts.
      </p>
    </div>
  </section><section class="section">
    <div class="container" style="max-width:880px">
      <h2 style="font-size:2.4rem">Accessibility notes</h2><p>
        Before launch, test the deployed website with keyboard navigation, screen readers, automated tools, and
        real device/browser combinations.
      </p>
    </div>
  </section></Layout
>
