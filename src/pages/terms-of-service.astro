---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Terms of Service | World of Spas" noindex={true}
  ><section class="page-hero">
    <div class="container page-hero__inner">
      <span class="eyebrow eyebrow--light">Legal</span><h1>Terms of Service</h1><p class="page-hero__copy">
        Template terms content for review before launch.
      </p>
    </div>
  </section><section class="section">
    <div class="container" style="max-width:880px">
      <div class="notice">Replace this placeholder with final business-specific legal terms.</div><h2
        style="font-size:2.4rem;margin-top:42px"
      >
        Use of this website
      </h2><p>
        Content, product details, availability, pricing, financing, and service details should be confirmed with
        a World of Spas representative before purchase.
      </p><h2 style="font-size:2.4rem;margin-top:42px">Product information</h2><p>
        Specifications, availability, colors, promotions, and delivery timing may vary by location and
        manufacturer program.
      </p>
    </div>
  </section></Layout
>
