---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Privacy Policy | World of Spas" noindex={true}
  ><section class="page-hero">
    <div class="container page-hero__inner">
      <span class="eyebrow eyebrow--light">Legal</span><h1>Privacy Policy</h1><p class="page-hero__copy">
        Template privacy content for development and review.
      </p>
    </div>
  </section><section class="section">
    <div class="container" style="max-width:880px">
      <div class="notice">
        Replace this with reviewed legal copy covering analytics, consent, SMS/email, CRM, form handling, and
        store-location routing.
      </div><h2 style="font-size:2.4rem;margin-top:42px">Information submitted through forms</h2><p>
        Forms may collect names, email addresses, phone numbers, preferred locations, product interests, and
        messages so the business or showroom can respond.
      </p><h2 style="font-size:2.4rem;margin-top:42px">Automatically collected information</h2><p>
        Production deployments may use logs, analytics, cookies, advertising pixels, and security tools.
        Document every production service before launch.
      </p>
    </div>
  </section></Layout
>
