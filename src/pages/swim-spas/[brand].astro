---
import Layout from '@/layouts/Layout.astro';
import ProductCard from '@/components/ProductCard.astro';
import InventoryToolbar from '@/components/InventoryToolbar.astro';
import Icon from '@/components/Icon.astro';
import { swimSpaBrands } from '@/data/brands';
import { getItemsByBrand } from '@/data/inventory';
export function getStaticPaths() {
  return swimSpaBrands.map((brand) => ({ params: { brand: brand.slug }, props: { brand } }));
}
const { brand } = Astro.props;
const items = getItemsByBrand(brand.slug, 'swim-spas');
---

<Layout title={`${brand.name} Swim Spas | World of Spas`} description={brand.description}>
  <section class="page-hero">
    <div class="container page-hero__inner">
      <div class="breadcrumbs">
        <a href="/">Home</a><span>/</span><a href="/swim-spas">Swim Spas</a><span>/</span><span
          >{brand.name}</span
        >
      </div><span class="eyebrow eyebrow--light">Swim spas by {brand.name}</span><h1>
        {brand.name} swim spas.
      </h1><p class="page-hero__copy">{brand.description}</p><div class="page-hero__actions">
        <a class="button button--light" href="#inventory">View models <Icon name="arrow" size={18} /></a><a
          class="button button--outline-light"
          href="/locations">Choose showroom</a
        >
      </div>
    </div>
  </section>
  <section class="section section--sand" id="inventory">
    <div class="container">
      <InventoryToolbar resultLabel={`${brand.name} swim spas`} showBrandFilter={false} /><div
        class="product-grid"
        data-sortable-grid
      >
        {
          items.map((item) => (
            <div
              data-name={item.name}
              data-featured={String(item.featured)}
              data-clearance={String(item.clearance)}
            >
              <ProductCard item={item} />
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
